{
  "name": "my-website",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "corepack pnpm --dir apps/frontend dev --host 127.0.0.1 --port 3001",
    "build": "corepack pnpm styles:wp-editor && corepack pnpm --dir apps/frontend build",
    "preview": "corepack pnpm --dir apps/frontend preview",
    "lint": "corepack pnpm --dir apps/frontend lint",
    "typecheck": "corepack pnpm --dir apps/frontend typecheck",
    "check": "corepack pnpm styles:wp-editor && corepack pnpm lint && corepack pnpm typecheck",
    "docker:up": "docker compose -f docker/compose.yaml -f docker/compose.dev.yaml up --build -d",
    "docker:down": "docker compose -f docker/compose.yaml -f docker/compose.dev.yaml down",
    "docker:logs": "docker compose -f docker/compose.yaml -f docker/compose.dev.yaml logs -f",
    "cms:seed-block-test-content": "docker compose -f docker/compose.yaml -f docker/compose.dev.yaml exec -T cms wp eval-file wp-content/plugins/project-bootstrap/dev-tools/seed-block-test-content.php --allow-root",
    "styles:wp-editor": "corepack pnpm --dir apps/frontend exec sass ../../packages/styles/context-role/_wp-editor.scss ../cms/wp-content/themes/my-website-editor-theme/editor.css --no-source-map",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
